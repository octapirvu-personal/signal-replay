# Supabase (multi-device cloud persistence). Copy to .env.local and fill in.
# Project Settings → API in your Supabase dashboard.
# The anon key is safe in a frontend bundle — Row-Level Security protects the data.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
